# 复制为 mail.env（已在 .gitignore）。直接运行主类时由 MailEnvEnvironmentPostProcessor 加载（UTF-8 Properties）。
# 勿提交真实授权码。

# profile「mail」由启动时的 MailEnvEnvironmentPostProcessor 自动激活，无需再写 spring.profiles.include。

MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=你的邮箱@qq.com
MAIL_PASSWORD=SMTP授权码
MAIL_FROM=你的邮箱@qq.com

# 使用 465 且走 SSL 时改为 true，并把 MAIL_PORT=465
MAIL_SMTP_SSL_ENABLE=false
MAIL_SMTP_STARTTLS_ENABLE=true
